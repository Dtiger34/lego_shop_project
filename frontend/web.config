<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <!-- Enable gzip compression for static files -->
    <httpCompression directory="%SystemDrive%\websites\web\temp\IIS Temporary Compressed Files">
      <scheme name="gzip" dll="%Windir%\system32\inetsrv\gzip.dll" staticCompressionLevel="9" />
      <staticTypes>
        <add mimeType="text/css" enabled="true" />
        <add mimeType="text/javascript" enabled="true" />
        <add mimeType="application/javascript" enabled="true" />
        <add mimeType="image/svg+xml" enabled="true" />
        <add mimeType="application/json" enabled="true" />
        <!-- Compress 3D model files -->
        <add mimeType="model/gltf-binary" enabled="true" />
        <add mimeType="model/gltf+json" enabled="true" />
        <add mimeType="application/octet-stream" enabled="true" />
      </staticTypes>
    </httpCompression>

    <!-- Set proper MIME type for GLB files -->
    <staticContent>
      <mimeMap fileExtension=".glb" mimeType="model/gltf-binary" />
      <mimeMap fileExtension=".gltf" mimeType="model/gltf+json" />
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAgeInSeconds="31536000" />
    </staticContent>

    <!-- Cache GLB files aggressively -->
    <caching>
      <profiles>
        <add extension=".glb" policy="CacheUntilChange" kernelCachePolicy="CacheUntilChange" />
        <add extension=".gltf" policy="CacheUntilChange" kernelCachePolicy="CacheUntilChange" />
      </profiles>
    </caching>

    <!-- Rewrite rules for better performance -->
    <rewrite>
      <rules>
        <!-- Cache static assets for long time -->
        <rule name="CacheStaticAssets" stopProcessing="true">
          <match url="^(.*\.(glb|gltf|js|css|jpg|png|gif|woff2?|ttf|svg))$" />
          <action type="Rewrite" url="{R:1}" />
          <serverVariables>
            <set name="HTTP_Cache_Control" value="public, max-age=31536000, immutable" />
          </serverVariables>
        </rule>
      </rules>
    </rewrite>

    <!-- Custom HTTP headers -->
    <httpProtocol>
      <customHeaders>
        <!-- Cache control for GLB files -->
        <add name="Cache-Control" value="public, max-age=31536000, immutable" />
        <!-- Enable compression -->
        <add name="Content-Encoding" value="gzip" />
        <!-- Security headers -->
        <add name="X-Content-Type-Options" value="nosniff" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>
</configuration>
